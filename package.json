{
  "name": "injection-range",
  "private": true,
  "version": "0.1.0",
  "description": "A daily puzzle built from a realistic AI-agent transcript: find the hidden prompt-injection payload before the agent acts on it.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint:content": "vitest run tests/pool-content-lint.test.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "9.20.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "9.20.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.9.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "8.50.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
